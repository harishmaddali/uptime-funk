# Database (SQLite file path for Drizzle + better-sqlite3)
DATABASE_URL="file:./dev.db"

# Better Auth (https://www.better-auth.com/docs/installation)
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
# Legacy alias still supported in code:
AUTH_URL="http://localhost:3000"

# Show Google / GitHub buttons in login & signup (set true when OAuth env vars are set)
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"
NEXT_PUBLIC_GITHUB_AUTH_ENABLED="false"

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Cron secret for /api/cron/check-monitors
CRON_SECRET="your-random-secret"

# Slack OAuth (optional)
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# Email — Resend (required for sign-up OTP + optional alert emails)
RESEND_API_KEY=""
EMAIL_FROM="Uptime Funk <onboarding@resend.dev>"

# SMS - Twilio (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=""
